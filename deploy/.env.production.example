APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-before-deploy
HOST=0.0.0.0
PORT=8080

# Zeabur persistent volume path
DATABASE_PATH=/data/tomorrow_question.sqlite3

# Flask serves the built frontend bundle from this directory
FRONTEND_DIST=/app/frontend/dist

SOCKETIO_ASYNC_MODE=eventlet

# Example: https://tomorrow-question.zeabur.app
CORS_ALLOWED_ORIGINS=https://your-zeabur-domain.zeabur.app

# Leave blank to use backend/config/balance/global.json
PHASE_DURATION_SECONDS=

# Leave blank to use the bundled balance config directory
BALANCE_CONFIG_DIR=
